{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "rootDir": "./src",
    "outDir": "./lib",
    "incremental": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "lib", "example", "scripts", "test-modules.ts"]
}
